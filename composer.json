{
  "name": "bugfix666/laravel-outbox",
  "description": "Transactional Outbox pattern for Laravel",
  "license": "MIT",
  "authors": [
    {
      "name": "bugfix666",
      "email": "appscenter@proton.me"
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "orchestra/testbench": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Bugfix666\\LaravelOutbox\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bugfix666\\LaravelOutbox\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Bugfix666\\LaravelOutbox\\Providers\\OutboxServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}